# Copie para .env e preencha — NUNCA commite o .env

APP_STORE_CONNECT_API_KEY_KEY_ID=XXXXXXXXXX
APP_STORE_CONNECT_API_KEY_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
APP_STORE_CONNECT_API_KEY_KEY_FILEPATH=fastlane/AuthKey_XXXXXXXXXX.p8
APPLE_TEAM_ID=XXXXXXXXXX

MATCH_GIT_URL=git@github.com:sua-org/certificates.git
MATCH_PASSWORD=senha_forte_para_criptografar_certificados

GOOGLE_PLAY_JSON_KEY=fastlane/google-play-key.json
ANDROID_KEYSTORE_PATH=android/app/keystore.jks
ANDROID_KEY_ALIAS=upload
ANDROID_STORE_PASSWORD=sua_senha_keystore
ANDROID_KEY_PASSWORD=sua_senha_chave

SLACK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
